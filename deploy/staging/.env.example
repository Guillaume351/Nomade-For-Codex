# Published images (GHCR)
CONTROL_API_IMAGE=ghcr.io/your-org/nomade-for-codex-control-api
TUNNEL_GATEWAY_IMAGE=ghcr.io/your-org/nomade-for-codex-tunnel-gateway
IMAGE_TAG=latest

# Exposed ports on the staging server
CONTROL_API_PORT=8080
TUNNEL_GATEWAY_PORT=8081

# Postgres
POSTGRES_DB=nomade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# App secrets (must be changed)
JWT_SECRET=change-me-long-random-secret
INTERNAL_GATEWAY_SECRET=change-me-another-long-random-secret

# Optional tuning
PREVIEW_BASE_DOMAIN=preview.staging.example.com
PREVIEW_BASE_ORIGIN=https://preview.staging.example.com
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
DEVICE_CODE_TTL_SEC=600
PAIRING_CODE_TTL_SEC=600
