# Published images (GHCR)
SAAS_IMAGE=ghcr.io/your-org/nomade-for-codex-saas
TUNNEL_GATEWAY_IMAGE=ghcr.io/your-org/nomade-for-codex-tunnel-gateway
IMAGE_TAG=latest

# Exposed ports on the staging server
SAAS_PORT=8080
TUNNEL_GATEWAY_PORT=8081

# Internal tunnel-gateway upstream to embedded compatibility backend
CONTROL_API_URL=http://saas:8090
# Optional override (normally keep default)
# COMPAT_BACKEND_URL=http://127.0.0.1:8090

# Postgres
POSTGRES_DB=nomade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# App secrets (must be changed)
JWT_SECRET=
INTERNAL_GATEWAY_SECRET=

# Optional tuning
PREVIEW_BASE_DOMAIN=preview.staging.example.com
PREVIEW_BASE_ORIGIN=https://preview.staging.example.com
APP_BASE_URL=https://app.staging.example.com
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
DEVICE_CODE_TTL_SEC=600
PAIRING_CODE_TTL_SEC=600
FREE_MAX_AGENTS=1
PAID_MAX_AGENTS=10
BETTER_AUTH_SECRET=
AUTH_EMAIL_MODE=log
AUTH_DEBUG_LOGS=false
HTTP_ACCESS_LOGS=true
# AUTH_SMTP_HOST=
# AUTH_SMTP_PORT=587
# AUTH_SMTP_SECURE=false
# AUTH_SMTP_USER=
# AUTH_SMTP_PASS=
# AUTH_SMTP_FROM=Nomade <no-reply@example.com>

# Optional social login providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_BUNDLE_ID=

# Optional Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
