# Published images (GHCR)
CONTROL_API_IMAGE=ghcr.io/your-org/nomade-for-codex-control-api
TUNNEL_GATEWAY_IMAGE=ghcr.io/your-org/nomade-for-codex-tunnel-gateway
IMAGE_TAG=latest

# Exposed ports on the staging server
CONTROL_API_PORT=8080
TUNNEL_GATEWAY_PORT=8081

# Postgres
POSTGRES_DB=nomade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# App secrets (must be changed)
JWT_SECRET=
INTERNAL_GATEWAY_SECRET=

# Optional tuning
PREVIEW_BASE_DOMAIN=preview.staging.example.com
PREVIEW_BASE_ORIGIN=https://preview.staging.example.com
APP_BASE_URL=https://app.staging.example.com
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000
DEVICE_CODE_TTL_SEC=600
PAIRING_CODE_TTL_SEC=600
FREE_MAX_AGENTS=1
PAID_MAX_AGENTS=10
LEGACY_DEVICE_APPROVE_ENABLED=false
DEV_LOGIN_ENABLED=false

# Optional OIDC
# OIDC_AUTHORIZATION_URL=
# OIDC_TOKEN_URL=
# OIDC_USERINFO_URL=
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://app.staging.example.com/auth/oidc/callback
# OIDC_SCOPE=openid profile email

# Optional Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
