{
  "name": "nomade-for-codex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "agent/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "dev:up": "docker compose -f deploy/selfhost/docker-compose.dev.yml up --build -d",
    "dev:down": "docker compose -f deploy/selfhost/docker-compose.dev.yml down -v",
    "dev:logs": "docker compose -f deploy/selfhost/docker-compose.dev.yml logs -f",
    "dev:control": "npm --workspace services/control-api run dev",
    "dev:gateway": "npm --workspace services/tunnel-gateway run dev",
    "dev:saas": "npm --workspace apps/saas run dev",
    "dev:agent": "npm --workspace agent/nomade-agent run dev --",
    "dev:agent:login": "npm --workspace agent/nomade-agent run login --",
    "dev:agent:whoami": "npm --workspace agent/nomade-agent run whoami --",
    "dev:agent:logout": "npm --workspace agent/nomade-agent run logout --",
    "dev:agent:pair": "npm --workspace agent/nomade-agent run pair --",
    "dev:agent:run": "npm --workspace agent/nomade-agent run dev:run",
    "dev:agent:setup": "npm --workspace agent/nomade-agent run cli -- install --no-start",
    "dev:agent:start": "npm --workspace agent/nomade-agent run cli -- start",
    "dev:agent:stop": "npm --workspace agent/nomade-agent run cli -- stop",
    "dev:agent:status": "npm --workspace agent/nomade-agent run cli -- status",
    "dev:agent:logs": "npm --workspace agent/nomade-agent run cli -- logs",
    "dev:agent:codex": "npm --workspace agent/nomade-agent run dev:run",
    "dev:full": "bash scripts/dev-full.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "test": "npm run -ws test"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
